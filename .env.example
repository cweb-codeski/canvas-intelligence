# Optional override (default: sqlite:///./app.db)
# DATABASE_URL=sqlite:///./app.db

# --- Manual-only demo (minimum) ---
OPENAI_API_KEY=your_openai_api_key_here
ENABLE_NOTION_SYNC=false

# --- Optional: Canvas ingest only (lazy; not needed to start the app) ---
# CANVAS_BASE_URL=https://your-school.instructure.com
# CANVAS_ACCESS_TOKEN=your_canvas_access_token_here

# --- Optional: Notion when ENABLE_NOTION_SYNC=true ---
# NOTION_API_KEY=your_notion_api_key_here
# NOTION_DATABASE_ID=your_notion_database_id_here
